<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Restore-time package sources. Authentication for the private axiomatrix
    feed comes from the per-user nuget.config in %APPDATA%\NuGet\ — never
    commit credentials here. CI uses ${{ secrets.GITHUB_TOKEN }} via the
    release workflow.

    The 'axiomatrix' source is currently declared but not yet consumed —
    no PackageReference resolves to it. It will be wired in once we adopt
    the AxiomCode.Mcp.Common, AxiomCode.Mcp.Hosting and AxiomCode.Build.Common
    packages from the shared infrastructure repo.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org"  value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="axiomatrix" value="https://nuget.pkg.github.com/axiomatrix/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
